# ---------------------------------------------------------------
# Flipbook Converter — example environment variables
# Copy this file to `.env` for local development.
# ---------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
CORS_ORIGIN=*

# Storage directories (relative paths resolve from project root)
UPLOAD_DIR=storage/uploads
OUTPUT_DIR=storage/output

# Upload limits
MAX_UPLOAD_SIZE_MB=50

# PDF rendering
PDF_DENSITY=150
PDF_PAGE_WIDTH=1240
PDF_PAGE_HEIGHT=1754
PDF_MAX_PAGES=300
PDF_CONCURRENCY=2
PDF_CHUNK_SIZE=5

# Image optimisation
IMAGE_QUALITY=82
IMAGE_MAX_WIDTH=1400

# Cleanup (milliseconds)
FILE_TTL_MS=7200000          # 2h
CLEANUP_INTERVAL_MS=1800000  # 30m
