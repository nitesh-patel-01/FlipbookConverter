{
  "name": "flipbook-converter",
  "version": "1.0.0",
  "description": "Convert PDFs and images into interactive flipbooks with page-turn animations. Download as a self-contained HTML ZIP.",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "cleanup": "node utils/cleanup.js --run"
  },
  "keywords": [
    "flipbook",
    "pdf-to-flipbook",
    "turn.js",
    "pdf-converter",
    "digital-flipbook",
    "page-flip"
  ],
  "author": "Flipbook Converter",
  "license": "MIT",
  "dependencies": {
    "archiver": "^7.0.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "file-type": "^16.5.4",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^3.3.7",
    "p-limit": "^3.1.0",
    "pdf2pic": "^3.1.3",
    "sharp": "^0.33.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
